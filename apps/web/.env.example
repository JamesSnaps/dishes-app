# ─── Local development env ────────────────────────────────────────────────────
# Copy to .env.local and adjust as needed:
#   cp apps/web/.env.example apps/web/.env.local
#
# These values match the offset host ports in docker-compose.dev.yml, so they
# work out of the box alongside other local Postgres/Redis instances. Start the
# infra first:
#   docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d
#   pnpm db:migrate
#   pnpm dev
#
# With NODE_ENV=development and no Authelia headers, the app logs in as a "Dev
# User" and auto-seeds the household with ~12 sample recipes, a meal plan, a
# shopping list and notes on first load. No Authelia setup required.

# Required — Postgres connection (matches docker-compose.dev.yml db on host :5433)
DATABASE_URL=postgresql://dishes:dishes@localhost:5433/dishes

# Required — 32+ char secret used to encrypt stored AI keys. Any stable string
# is fine for local dev.
ENCRYPTION_KEY=dev-local-encryption-key-change-me-32chars

# Optional — Redis for rate limiting (matches docker-compose.dev.yml on host :6380).
# Rate limiting is skipped entirely if this is absent.
REDIS_URL=redis://localhost:6380

# Optional — S3-compatible storage for recipe images (matches MinIO on host :9002).
# Image upload is disabled if these are absent; the rest of the app works fine.
# S3_ENDPOINT=http://localhost:9002
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_BUCKET=dishes
# S3_PUBLIC_URL=http://localhost:9002/dishes

# Optional — Authelia portal URL. Enables the "Log out" link in the sidebar.
# Leave blank for local dev (there's no real Authelia).
# NEXT_PUBLIC_AUTHELIA_URL=https://auth.example.com

# Optional — override the Authelia header names if your proxy differs.
# AUTHELIA_USER_HEADER=Remote-User
# AUTHELIA_NAME_HEADER=Remote-Name
# AUTHELIA_GROUPS_HEADER=Remote-Groups

# Optional — Web Push (notifications). Generate with: npx web-push generate-vapid-keys
# VAPID_SUBJECT=mailto:you@example.com
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
