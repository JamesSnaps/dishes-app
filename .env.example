# Copy to .env.local for local development
# Copy to .env for Docker Compose

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://dishes:dishes@localhost:5432/dishes"

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── S3 / Object Storage ─────────────────────────────────────────────────────
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="dishes"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ─── Authelia ────────────────────────────────────────────────────────────────
# Header Authelia injects after authentication (adjust to your Authelia config)
AUTHELIA_USER_HEADER="Remote-User"
AUTHELIA_NAME_HEADER="Remote-Name"
AUTHELIA_GROUPS_HEADER="Remote-Groups"
# Authelia portal URL used for the logout link (e.g. https://auth.yourdomain.com)
# Leave blank to hide the logout option (e.g. in local dev without Authelia)
NEXT_PUBLIC_AUTHELIA_URL=""

# ─── Encryption ──────────────────────────────────────────────────────────────
# 32-byte hex string for encrypting AI API keys at rest
ENCRYPTION_KEY="change-me-to-a-32-byte-hex-string-please"

# ─── Web Push (optional) ─────────────────────────────────────────────────────
# Enables household push notifications (shared shopping-list / meal-plan changes).
# Generate a key pair once with:  npx web-push generate-vapid-keys
# Keep these STABLE — rotating the private key invalidates all existing
# subscriptions and everyone has to re-enable notifications. Leave unset to
# disable push (the rest of the app works fine without it).
# VAPID_SUBJECT="mailto:you@example.com"
# VAPID_PUBLIC_KEY=""
# VAPID_PRIVATE_KEY=""
